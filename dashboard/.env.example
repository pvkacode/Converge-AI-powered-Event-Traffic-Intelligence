# FastAPI inference API (Worked Example live trace)
# Local default: http://127.0.0.1:8000
# Production: https://your-service.onrender.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional — override CSV root (default: ../outputs or ./outputs after Vercel sync)
# OUTPUTS_DIR=/absolute/path/to/outputs

# Optional — events_clean.csv for live overview KPIs (falls back to batch figures)
# DATA_DIR=/absolute/path/to/data
