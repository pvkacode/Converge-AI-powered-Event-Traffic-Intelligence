# Repo root (default: parent of api/)
# ASTRAM_ROOT=/opt/render/project/src

# Pipeline outputs (default: $ASTRAM_ROOT/outputs)
# OUTPUTS_DIR=/opt/render/project/src/outputs

# Cleaned events for live Layer 1 (optional; falls back to duration_lookup.csv)
# DATA_DIR=/opt/render/project/src/data

# Comma-separated allowed origins (default: * for dev)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-*.vercel.app
